# Copy to .env for local development (never commit .env)

# Google Generative AI (Gemini)
GOOGLE_API_KEY=

# Database: leave unset for local SQLite. On Railway, reference Postgres service → DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Cloudflare R2 (S3 API) — optional; if unset, RFP attachments use local uploads/ or /tmp/sap_uploads
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
