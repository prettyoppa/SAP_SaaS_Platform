# Copy to .env for local development (never commit .env)

# Google Generative AI (Gemini)
GOOGLE_API_KEY=
# 선택: 모델 ID (기본 gemini-2.5-flash). Google이 구형 이름을 막으면 여기만 바꿈.
# GEMINI_MODEL=gemini-2.5-flash

# Database: leave unset for local SQLite.
# On Railway: keep Postgres DATABASE_URL on the web service (user/password/db name).
# If internal host fails DNS, set DATABASE_PUBLIC_URL to either:
#   - full postgresql://...@xxxx.proxy.rlwy.net:PORT/railway
#   - or only host:port (e.g. shinkansen.proxy.rlwy.net:46213) — merged into DATABASE_URL
# DATABASE_URL=postgresql://...
# DATABASE_PUBLIC_URL=shinkansen.proxy.rlwy.net:46213

# Cloudflare R2 (S3 API) — optional; if unset, RFP attachments use local uploads/ or /tmp/sap_uploads
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# ABAP 분석 / 이어서 질문 — 선택(미설정 시 코드 기본값 사용)
# ABAP_ANALYSIS_TRIM_MAX_LINES=4000 … Crew 초기·재분석(_trim_code 휴리스틱). 「파일 앞 N줄」이 아님.
# ABAP_FOLLOWUP_FULL_BELOW_CHARS=1500000 … 해당 문자 수 이하이면 후속 채팅에 제출 전본 포함(Python len).
# ABAP_FOLLOWUP_CODE_HARD_CAP_CHARS=1850000 … 후속 채팅 코드 블록 절대 상한.
# ABAP_FOLLOWUP_TRIM_MAX_LINES=12000 … 전본 초과 시 슬롯 균형 트림 시 총 줄 예산 상한.

# Stripe — 유료 개발 의뢰(Checkout Session, one-time)
# Product/Price 생성 후 price_ ID를 넣고, Dashboard → Webhooks에서
# https://<도메인>/payments/stripe/webhook + checkout.session.completed 선택
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_RFP_DEVELOPMENT=price_xxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

