# Copy to .env for local development (never commit .env)

# Google Generative AI (Gemini)
GOOGLE_API_KEY=

# Database: leave unset for local SQLite.
# On Railway: reference Postgres → DATABASE_URL. If host is postgres.railway.internal and the
# app logs "could not translate host name", add Postgres *public* TCP URL as DATABASE_PUBLIC_URL
# (takes precedence over DATABASE_URL).
# DATABASE_URL=postgresql://...
# DATABASE_PUBLIC_URL=postgresql://...@xxxx.proxy.rlwy.net:PORT/railway

# Cloudflare R2 (S3 API) — optional; if unset, RFP attachments use local uploads/ or /tmp/sap_uploads
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
