# Copy to .env for local development (never commit .env)

# Google Generative AI (Gemini)
GOOGLE_API_KEY=

# Database: leave unset for local SQLite.
# On Railway: keep Postgres DATABASE_URL on the web service (user/password/db name).
# If internal host fails DNS, set DATABASE_PUBLIC_URL to either:
#   - full postgresql://...@xxxx.proxy.rlwy.net:PORT/railway
#   - or only host:port (e.g. shinkansen.proxy.rlwy.net:46213) — merged into DATABASE_URL
# DATABASE_URL=postgresql://...
# DATABASE_PUBLIC_URL=shinkansen.proxy.rlwy.net:46213

# Cloudflare R2 (S3 API) — optional; if unset, RFP attachments use local uploads/ or /tmp/sap_uploads
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
